      "Bash(gh pr create *)",
      "Bash(git commit --no-verify:*)",
      "Bash(git commit -m * --no-verify*)"
    ],
    "allow": [
      "Bash(git:*)",
      "Bash(chmod:*)",
      "Bash(grep -E \"\\\\.\\(tsx|ts\\)$\")",
      "Bash(npx tsc:*)",
      "Bash(cargo check:*)",
