      "Bash(npm ls:*)",
      "Bash(npm install:*)",
      "Read(//Users/lt-macbookpro-0010/.cargo/bin/**)",
      "Read(//Users/lt-macbookpro-0010/.cargo/**)",
      "Read(//Users/lt-macbookpro-0010/.claude/commands/**)",
      "Read(//Users/lt-macbookpro-0010/.claude/**)",
      "Bash(gh auth:*)",
      "Bash(gh api:*)",
      "Bash(node:*)",
      "Bash(zsh:*)",
      "Bash(sh -c 'echo $PATH')",
      "Bash(export PATH=\"$HOME/.cargo/bin:$PATH\")",
      "Bash(cargo tauri:*)",
      "Bash(cargo clean:*)",
      "Bash(npx tauri:*)",
      "Bash(npx vite:*)",
      "Bash(pkill -f \"tauri dev\")",
      "Bash(pkill -f \"cargo-tauri\")",
      "Bash(lsof -ti:5173)",
      "Bash(xargs kill:*)",
